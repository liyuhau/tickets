{
  "name": "bizdb1-sharding-connector",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "mysql",
    "database.port": "3306",
    "database.user": "debezium",
    "database.password": "dbz",
    "database.server.id": "184056",
    "topic.prefix": "cdc-shard1",
    "database.include.list": "bizdb_1",
    "table.include.list": "bizdb_1.booking_0,bizdb_1.booking_1",
    "schema.history.internal.kafka.bootstrap.servers": "kafka:29092",
    "schema.history.internal.kafka.topic": "schema-history.bizdb1",
    "include.schema.changes": "false",
    "snapshot.mode": "initial",

    "transforms": "route",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "cdc-shard1\\.bizdb_1\\.booking_.*",
    "transforms.route.replacement": "cdc.bizdb.booking"
  }
}
